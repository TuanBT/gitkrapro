{
  "compilerOptions": {
    "lib": [
      "ES2020"
    ],
    "module": "commonjs",
    "moduleResolution": "node",
    "newLine": "lf",
    "outDir": "./dist",
    "removeComments": true,
    "sourceMap": false,
    "strict": true,
    "target": "ES2020",
    "noImplicitReturns": true,
    "skipLibCheck": true
  },
  "exclude": [
    "./node_modules"
  ],
  "include": [
    "./**/*.ts"
  ]
}
